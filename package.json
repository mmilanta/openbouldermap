{
  "name": "openbouldermap",
  "version": "0.2.0",
  "private": true,
  "description": "Worldwide bouldering map — basemap from OpenFreeMap, climbing data from self-hosted PMTiles.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "build-tiles": "bash scripts/build-climbing-tiles.sh",
    "serve-tiles": "npx tsx scripts/serve-tiles.ts 8081",
    "themes-json": "npx tsx scripts/generate-themes-json.ts"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "dependencies": {
    "maplibre-gl": "^4.5.0",
    "pmtiles": "^3.0.7"
  }
}
